{
  "schema_version": "1",
  "description": "Canonical catalog of all physical output types that can appear across MC codes in this benchmark. Each key encodes {geometry}.{QUANTITY}.{filter}.{medium}[.vs_{diff_axis}]. Manifests reference these keys per file via the output_type field.",
  "geometry_classes": {
    "depth_Z": {
      "description": "1D depth profile along the beam (Z) axis with narrow lateral acceptance (1×1 cm²)",
      "dimensionality": 1,
      "render_as": "line_plot",
      "axis_x": {"quantity": "depth", "unit": "cm"}
    },
    "target": {
      "description": "Single-volume integrated scalar in the target detector (5×5×2 mm³ silicon)",
      "dimensionality": 0,
      "render_as": "scalar"
    },
    "spectrum_target": {
      "description": "1D differential particle spectrum (fluence vs stopping quantity) scored in the target volume",
      "dimensionality": 1,
      "render_as": "spectrum_plot"
    },
    "map_XZ": {
      "description": "2D longitudinal (X–Z) dose or fluence map",
      "dimensionality": 2,
      "render_as": "heatmap",
      "axis_x": {"quantity": "x", "unit": "cm"},
      "axis_y": {"quantity": "depth", "unit": "cm"}
    },
    "map_XY": {
      "description": "2D transverse (X–Y) dose or fluence map",
      "dimensionality": 2,
      "render_as": "heatmap",
      "axis_x": {"quantity": "x", "unit": "cm"},
      "axis_y": {"quantity": "y", "unit": "cm"}
    }
  },
  "output_types": {

    "depth_Z.FLUENCE.all.Si":     {"geometry": "depth_Z", "quantity": "FLUENCE", "filter": "all",     "medium": "Si",  "label": "Fluence – all particles in Si",           "axis_y": {"quantity": "fluence", "unit": "1/cm²/primary"}, "render_as": "line_plot"},
    "depth_Z.FLUENCE.primary.Si": {"geometry": "depth_Z", "quantity": "FLUENCE", "filter": "primary", "medium": "Si",  "label": "Fluence – primary protons in Si",         "axis_y": {"quantity": "fluence", "unit": "1/cm²/primary"}, "render_as": "line_plot"},
    "depth_Z.FLUENCE.protons.Si": {"geometry": "depth_Z", "quantity": "FLUENCE", "filter": "protons", "medium": "Si",  "label": "Fluence – all protons in Si",             "axis_y": {"quantity": "fluence", "unit": "1/cm²/primary"}, "render_as": "line_plot"},
    "depth_Z.FLUENCE.all.H2O":    {"geometry": "depth_Z", "quantity": "FLUENCE", "filter": "all",     "medium": "H2O", "label": "Fluence – all particles in H₂O",          "axis_y": {"quantity": "fluence", "unit": "1/cm²/primary"}, "render_as": "line_plot"},

    "depth_Z.DOSE.all.Si":        {"geometry": "depth_Z", "quantity": "DOSE",    "filter": "all",     "medium": "Si",  "label": "Dose – all particles in Si",              "axis_y": {"quantity": "dose",    "unit": "MeV/g/primary"}, "render_as": "line_plot"},
    "depth_Z.DOSE.protons.Si":    {"geometry": "depth_Z", "quantity": "DOSE",    "filter": "protons", "medium": "Si",  "label": "Dose – all protons in Si",                "axis_y": {"quantity": "dose",    "unit": "MeV/g/primary"}, "render_as": "line_plot"},
