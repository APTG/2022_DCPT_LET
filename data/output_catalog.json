{
  "schema_version": "1",
  "description": "Canonical catalog of all physical output types in this benchmark. Key format: {geometry}.{QUANTITY}.{filter}.{medium}[.vs_{diff_axis}]. The medium suffix encodes the stopping-power table used: '.Si' means no explicit medium specifier in the SH12A detect.dat (dose/LET scored to the actual transport material, which is solid water + PMMA in this geometry); '.H2O' means the in_Water setting was applied (water stopping powers). Exception: spectrum_target keys with '.Si' use the explicit in_Si stopping-power setting.",
  "geometry_classes": {
    "depth_Z": {
      "description": "1D depth profile along the beam (Z) axis with narrow lateral acceptance (1×1 cm²)",
      "dimensionality": 1,
      "render_as": "line_plot",
      "axis_x": {"quantity": "depth", "unit": "cm"}
    },
    "target": {
      "description": "Single-volume integrated scalar in the target detector (5×5×2 mm³ silicon)",
      "dimensionality": 0,
      "render_as": "scalar"
    },
    "spectrum_target": {
      "description": "1D differential particle spectrum (fluence vs stopping quantity) scored in the target volume",
      "dimensionality": 1,
      "render_as": "spectrum_plot"
    },
    "map_XZ": {
      "description": "2D longitudinal (X–Z) dose or fluence map",
      "dimensionality": 2,
      "render_as": "heatmap",
      "axis_x": {"quantity": "x", "unit": "cm"},
      "axis_y": {"quantity": "depth", "unit": "cm"}
    },
    "map_XY": {
      "description": "2D transverse (X–Y) dose or fluence map",
      "dimensionality": 2,
      "render_as": "heatmap",
      "axis_x": {"quantity": "x", "unit": "cm"},
      "axis_y": {"quantity": "y", "unit": "cm"}
    }
  },
  "output_types": {

    "depth_Z.FLUENCE.all.Si":     {"geometry": "depth_Z", "quantity": "FLUENCE", "filter": "all",     "medium": "Si",  "label": "Fluence",                          "axis_y": {"quantity": "fluence", "unit": "1/cm²/primary"}, "render_as": "line_plot"},
    "depth_Z.FLUENCE.primary.Si": {"geometry": "depth_Z", "quantity": "FLUENCE", "filter": "primary", "medium": "Si",  "label": "Fluence (primary protons)",        "axis_y": {"quantity": "fluence", "unit": "1/cm²/primary"}, "render_as": "line_plot"},
    "depth_Z.FLUENCE.protons.Si": {"geometry": "depth_Z", "quantity": "FLUENCE", "filter": "protons", "medium": "Si",  "label": "Fluence (all protons)",            "axis_y": {"quantity": "fluence", "unit": "1/cm²/primary"}, "render_as": "line_plot"},
    "depth_Z.FLUENCE.all.H2O":    {"geometry": "depth_Z", "quantity": "FLUENCE", "filter": "all",     "medium": "H2O", "label": "Fluence (water scorer)",           "axis_y": {"quantity": "fluence", "unit": "1/cm²/primary"}, "render_as": "line_plot"},

    "depth_Z.DOSE.all.Si":        {"geometry": "depth_Z", "quantity": "DOSE",    "filter": "all",     "medium": "Si",  "label": "Dose",                             "axis_y": {"quantity": "dose",    "unit": "MeV/g/primary"}, "render_as": "line_plot"},
    "depth_Z.DOSE.protons.Si":    {"geometry": "depth_Z", "quantity": "DOSE",    "filter": "protons", "medium": "Si",  "label": "Dose (protons)",                   "axis_y": {"quantity": "dose",    "unit": "MeV/g/primary"}, "render_as": "line_plot"},
    "depth_Z.DOSE.all.H2O":       {"geometry": "depth_Z", "quantity": "DOSE",    "filter": "all",     "medium": "H2O", "label": "Dose-to-water",                    "axis_y": {"quantity": "dose",    "unit": "MeV/g/primary"}, "render_as": "line_plot"},
    "depth_Z.DOSE.protons.H2O":   {"geometry": "depth_Z", "quantity": "DOSE",    "filter": "protons", "medium": "H2O", "label": "Dose-to-water (protons)",          "axis_y": {"quantity": "dose",    "unit": "MeV/g/primary"}, "render_as": "line_plot"},

    "depth_Z.DLET.all.Si":        {"geometry": "depth_Z", "quantity": "DLET",    "filter": "all",     "medium": "Si",  "label": "D-LET",                            "axis_y": {"quantity": "DLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},
    "depth_Z.DLET.primary.Si":    {"geometry": "depth_Z", "quantity": "DLET",    "filter": "primary", "medium": "Si",  "label": "D-LET (primary protons)",          "axis_y": {"quantity": "DLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},
    "depth_Z.DLET.protons.Si":    {"geometry": "depth_Z", "quantity": "DLET",    "filter": "protons", "medium": "Si",  "label": "D-LET (protons)",                  "axis_y": {"quantity": "DLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},
    "depth_Z.DLET.all.H2O":       {"geometry": "depth_Z", "quantity": "DLET",    "filter": "all",     "medium": "H2O", "label": "D-LET water",                      "axis_y": {"quantity": "DLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},
    "depth_Z.DLET.primary.H2O":   {"geometry": "depth_Z", "quantity": "DLET",    "filter": "primary", "medium": "H2O", "label": "D-LET water (primary protons)",    "axis_y": {"quantity": "DLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},
    "depth_Z.DLET.protons.H2O":   {"geometry": "depth_Z", "quantity": "DLET",    "filter": "protons", "medium": "H2O", "label": "D-LET water (protons)",            "axis_y": {"quantity": "DLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},

    "depth_Z.TLET.all.Si":        {"geometry": "depth_Z", "quantity": "TLET",    "filter": "all",     "medium": "Si",  "label": "T-LET",                            "axis_y": {"quantity": "TLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},
    "depth_Z.TLET.primary.Si":    {"geometry": "depth_Z", "quantity": "TLET",    "filter": "primary", "medium": "Si",  "label": "T-LET (primary protons)",          "axis_y": {"quantity": "TLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},
    "depth_Z.TLET.protons.Si":    {"geometry": "depth_Z", "quantity": "TLET",    "filter": "protons", "medium": "Si",  "label": "T-LET (protons)",                  "axis_y": {"quantity": "TLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},
    "depth_Z.TLET.all.H2O":       {"geometry": "depth_Z", "quantity": "TLET",    "filter": "all",     "medium": "H2O", "label": "T-LET water",                      "axis_y": {"quantity": "TLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},
    "depth_Z.TLET.primary.H2O":   {"geometry": "depth_Z", "quantity": "TLET",    "filter": "primary", "medium": "H2O", "label": "T-LET water (primary protons)",    "axis_y": {"quantity": "TLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},
    "depth_Z.TLET.protons.H2O":   {"geometry": "depth_Z", "quantity": "TLET",    "filter": "protons", "medium": "H2O", "label": "T-LET water (protons)",            "axis_y": {"quantity": "TLET",    "unit": "MeV/cm"},        "render_as": "line_plot"},

    "depth_Z.DQEFF.all.Si":       {"geometry": "depth_Z", "quantity": "DQEFF",   "filter": "all",     "medium": "Si",  "label": "D-Qeff",                           "axis_y": {"quantity": "DQEFF",   "unit": ""},              "render_as": "line_plot"},
    "depth_Z.DQEFF.primary.Si":   {"geometry": "depth_Z", "quantity": "DQEFF",   "filter": "primary", "medium": "Si",  "label": "D-Qeff (primary protons)",         "axis_y": {"quantity": "DQEFF",   "unit": ""},              "render_as": "line_plot"},
    "depth_Z.DQEFF.protons.Si":   {"geometry": "depth_Z", "quantity": "DQEFF",   "filter": "protons", "medium": "Si",  "label": "D-Qeff (protons)",                 "axis_y": {"quantity": "DQEFF",   "unit": ""},              "render_as": "line_plot"},
    "depth_Z.TQEFF.all.Si":       {"geometry": "depth_Z", "quantity": "TQEFF",   "filter": "all",     "medium": "Si",  "label": "T-Qeff",                           "axis_y": {"quantity": "TQEFF",   "unit": ""},              "render_as": "line_plot"},
    "depth_Z.TQEFF.primary.Si":   {"geometry": "depth_Z", "quantity": "TQEFF",   "filter": "primary", "medium": "Si",  "label": "T-Qeff (primary protons)",         "axis_y": {"quantity": "TQEFF",   "unit": ""},              "render_as": "line_plot"},
    "depth_Z.TQEFF.protons.Si":   {"geometry": "depth_Z", "quantity": "TQEFF",   "filter": "protons", "medium": "Si",  "label": "T-Qeff (protons)",                 "axis_y": {"quantity": "TQEFF",   "unit": ""},              "render_as": "line_plot"},

    "target.FLUENCE.all.Si":      {"geometry": "target",  "quantity": "FLUENCE", "filter": "all",     "medium": "Si",  "label": "Fluence",                          "render_as": "scalar"},
    "target.FLUENCE.primary.Si":  {"geometry": "target",  "quantity": "FLUENCE", "filter": "primary", "medium": "Si",  "label": "Fluence (primary protons)",        "render_as": "scalar"},
    "target.FLUENCE.protons.Si":  {"geometry": "target",  "quantity": "FLUENCE", "filter": "protons", "medium": "Si",  "label": "Fluence (all protons)",            "render_as": "scalar"},
    "target.DOSE.all.Si":         {"geometry": "target",  "quantity": "DOSE",    "filter": "all",     "medium": "Si",  "label": "Dose",                             "render_as": "scalar"},
    "target.DOSE.all.H2O":        {"geometry": "target",  "quantity": "DOSE",    "filter": "all",     "medium": "H2O", "label": "Dose-to-water",                    "render_as": "scalar"},
    "target.DLET.all.Si":         {"geometry": "target",  "quantity": "DLET",    "filter": "all",     "medium": "Si",  "label": "D-LET",                            "render_as": "scalar"},
    "target.DLET.primary.Si":     {"geometry": "target",  "quantity": "DLET",    "filter": "primary", "medium": "Si",  "label": "D-LET (primary protons)",          "render_as": "scalar"},
    "target.DLET.protons.Si":     {"geometry": "target",  "quantity": "DLET",    "filter": "protons", "medium": "Si",  "label": "D-LET (protons)",                  "render_as": "scalar"},
    "target.DLET.all.H2O":        {"geometry": "target",  "quantity": "DLET",    "filter": "all",     "medium": "H2O", "label": "D-LET water",                      "render_as": "scalar"},
    "target.DLET.primary.H2O":    {"geometry": "target",  "quantity": "DLET",    "filter": "primary", "medium": "H2O", "label": "D-LET water (primary protons)",    "render_as": "scalar"},
    "target.DLET.protons.H2O":    {"geometry": "target",  "quantity": "DLET",    "filter": "protons", "medium": "H2O", "label": "D-LET water (protons)",            "render_as": "scalar"},
    "target.TLET.all.Si":         {"geometry": "target",  "quantity": "TLET",    "filter": "all",     "medium": "Si",  "label": "T-LET",                            "render_as": "scalar"},
    "target.TLET.primary.Si":     {"geometry": "target",  "quantity": "TLET",    "filter": "primary", "medium": "Si",  "label": "T-LET (primary protons)",          "render_as": "scalar"},
    "target.TLET.protons.Si":     {"geometry": "target",  "quantity": "TLET",    "filter": "protons", "medium": "Si",  "label": "T-LET (protons)",                  "render_as": "scalar"},
    "target.TLET.all.H2O":        {"geometry": "target",  "quantity": "TLET",    "filter": "all",     "medium": "H2O", "label": "T-LET water",                      "render_as": "scalar"},
    "target.TLET.primary.H2O":    {"geometry": "target",  "quantity": "TLET",    "filter": "primary", "medium": "H2O", "label": "T-LET water (primary protons)",    "render_as": "scalar"},
    "target.TLET.protons.H2O":    {"geometry": "target",  "quantity": "TLET",    "filter": "protons", "medium": "H2O", "label": "T-LET water (protons)",            "render_as": "scalar"},
    "target.DQEFF.all.Si":        {"geometry": "target",  "quantity": "DQEFF",   "filter": "all",     "medium": "Si",  "label": "D-Qeff",                           "render_as": "scalar"},
    "target.DQEFF.primary.Si":    {"geometry": "target",  "quantity": "DQEFF",   "filter": "primary", "medium": "Si",  "label": "D-Qeff (primary protons)",         "render_as": "scalar"},
    "target.DQEFF.protons.Si":    {"geometry": "target",  "quantity": "DQEFF",   "filter": "protons", "medium": "Si",  "label": "D-Qeff (protons)",                 "render_as": "scalar"},
    "target.TQEFF.all.Si":        {"geometry": "target",  "quantity": "TQEFF",   "filter": "all",     "medium": "Si",  "label": "T-Qeff",                           "render_as": "scalar"},
    "target.TQEFF.primary.Si":    {"geometry": "target",  "quantity": "TQEFF",   "filter": "primary", "medium": "Si",  "label": "T-Qeff (primary protons)",         "render_as": "scalar"},
    "target.TQEFF.protons.Si":    {"geometry": "target",  "quantity": "TQEFF",   "filter": "protons", "medium": "Si",  "label": "T-Qeff (protons)",                 "render_as": "scalar"},

    "spectrum_target.FLUENCE.all.Si.vs_DEDX":       {"geometry": "spectrum_target", "quantity": "FLUENCE", "filter": "all",     "medium": "Si",  "diff_axis": "DEDX", "label": "Fluence spectrum vs dE/dx (Si stop. pow.)",          "axis_x": {"quantity": "dE/dx", "unit": "keV/µm"}, "axis_y": {"quantity": "fluence differential", "unit": "1/(cm² primary keV/µm)"}, "render_as": "spectrum_plot"},
    "spectrum_target.FLUENCE.primary.Si.vs_LET":    {"geometry": "spectrum_target", "quantity": "FLUENCE", "filter": "primary", "medium": "Si",  "diff_axis": "LET",  "label": "Fluence spectrum vs LET (primary, Si stop. pow.)",   "axis_x": {"quantity": "LET",   "unit": "keV/µm"}, "axis_y": {"quantity": "fluence differential", "unit": "1/(cm² primary keV/µm)"}, "render_as": "spectrum_plot"},
    "spectrum_target.FLUENCE.primary.Si.vs_DEDX":   {"geometry": "spectrum_target", "quantity": "FLUENCE", "filter": "primary", "medium": "Si",  "diff_axis": "DEDX", "label": "Fluence spectrum vs dE/dx (primary, Si stop. pow.)", "axis_x": {"quantity": "dE/dx", "unit": "keV/µm"}, "axis_y": {"quantity": "fluence differential", "unit": "1/(cm² primary keV/µm)"}, "render_as": "spectrum_plot"},
    "spectrum_target.FLUENCE.all.H2O.vs_DEDX":      {"geometry": "spectrum_target", "quantity": "FLUENCE", "filter": "all",     "medium": "H2O", "diff_axis": "DEDX", "label": "Fluence spectrum vs dE/dx (water stop. pow.)",       "axis_x": {"quantity": "dE/dx", "unit": "keV/µm"}, "axis_y": {"quantity": "fluence differential", "unit": "1/(cm² primary keV/µm)"}, "render_as": "spectrum_plot"},
    "spectrum_target.FLUENCE.primary.H2O.vs_LET":   {"geometry": "spectrum_target", "quantity": "FLUENCE", "filter": "primary", "medium": "H2O", "diff_axis": "LET",  "label": "Fluence spectrum vs LET (primary, water stop. pow.)", "axis_x": {"quantity": "LET",   "unit": "keV/µm"}, "axis_y": {"quantity": "fluence differential", "unit": "1/(cm² primary keV/µm)"}, "render_as": "spectrum_plot"},

    "map_XZ.DOSE.all.Si":         {"geometry": "map_XZ",  "quantity": "DOSE",    "filter": "all",     "medium": "Si",  "label": "Dose (longitudinal map, XZ)",      "render_as": "heatmap"},
    "map_XY.DOSE.all.Si":         {"geometry": "map_XY",  "quantity": "DOSE",    "filter": "all",     "medium": "Si",  "label": "Dose (transverse map, XY)",        "render_as": "heatmap"}
  }
}
