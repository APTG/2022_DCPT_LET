    "depth_Z.DOSE.protons.H2O":   {"geometry": "depth_Z", "quantity": "DOSE",    "filter": "protons", "medium": "H2O", "label": "Dose – all protons in H₂O",               "axis_y": {"quantity": "dose",    "unit": "MeV/g/primary"}, "render_as": "line_plot"},

