{
  "schema_version": "1",
  "description": "Canonical catalog of all physical output types in this benchmark. Key format: {geometry}.{QUANTITY}.{filter}.{medium}[.vs_{diff_axis}]. Medium suffix: 'mat' = no material override, scored to the actual transport medium (solid water + PMMA in this geometry); 'Si' = explicit in_Si stopping-power setting (spectrum_target only); 'H2O' = explicit in_Water stopping-power setting.",
  "geometry_classes": {
    "depth_Z": {
      "description": "1D depth profile along the beam (Z) axis with narrow lateral acceptance (1×1 cm²)",
      "dimensionality": 1,
      "render_as": "line_plot",
      "axis_x": {
        "quantity": "depth",
        "unit": "cm"
      }
    },
    "target": {
      "description": "Single-volume integrated scalar in the target detector (5×5×2 mm³ silicon)",
      "dimensionality": 0,
      "render_as": "scalar"
    },
    "spectrum_target": {
      "description": "1D differential particle spectrum (fluence vs stopping quantity) scored in the target volume",
      "dimensionality": 1,
      "render_as": "spectrum_plot"
    },
    "map_XZ": {
      "description": "2D longitudinal (X–Z) dose or fluence map",
      "dimensionality": 2,
      "render_as": "heatmap",
      "axis_x": {
        "quantity": "x",
        "unit": "cm"
      },
      "axis_y": {
        "quantity": "depth",
        "unit": "cm"
      }
    },
    "map_XY": {
      "description": "2D transverse (X–Y) dose or fluence map",
      "dimensionality": 2,
      "render_as": "heatmap",
      "axis_x": {
        "quantity": "x",
        "unit": "cm"
      },
      "axis_y": {
        "quantity": "y",
        "unit": "cm"
      }
    }
  },
  "output_types": {
    "depth_Z.FLUENCE.all.mat": {
      "geometry": "depth_Z",
      "quantity": "FLUENCE",
      "filter": "all",
      "medium": "mat",
      "label": "Fluence",
      "axis_y": {
        "quantity": "fluence",
        "unit": "1/cm²/primary"
      },
      "render_as": "line_plot"
    },
